<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.shawn.portfolio-watcher-daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/shawn/workspace/portfolio-watcher/run.sh</string>
        <string>daily</string>
    </array>

    <!-- Tue–Sat 09:00 Taipei (Mac local +0800; launchd Weekday: Tue=2 … Sat=6). Each run
         reviews the PRIOR US session's 16:00 ET close, which by 09:00 Taipei is fully
         settled (≈5h after close, past after-hours) and well before the next pre-market —
         so no pre-market noise contaminates the read. Mapping: Tue→Mon, Wed→Tue, Thu→Wed,
         Fri→Thu, Sat→Fri. The Saturday run is what reviews Friday's close (incl. the §1.6
         binding soft triggers); the weekly §2 review runs Sat 09:30, after this. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Weekday</key><integer>6</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key><string>/Users/shawn</string>
        <key>PATH</key><string>/Users/shawn/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/shawn/workspace/portfolio-watcher/logs/launchd-daily.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/shawn/workspace/portfolio-watcher/logs/launchd-daily.err</string>

    <key>RunAtLoad</key>
    <false/>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
