# IB Gateway credentials & settings for docker-compose.ib-gateway.yml
# Copy to `.env.ib-gateway` and fill in your IBKR credentials, then:
#   docker compose -f docker-compose.ib-gateway.yml --env-file .env.ib-gateway up -d
# The real .env.ib-gateway is gitignored — NEVER commit your credentials.

# --- IBKR login (used by IBC for automated login) ---
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# Trading mode: "live" or "paper"
TRADING_MODE=live

# API access. "no" = the API can place/modify/cancel orders (required for the
# interactive `watcher-followup` order placement). "yes" = read-only API (quotes,
# positions, history) — the scheduled watcher run alone would be fine with "yes",
# but followup order placement needs "no".
READ_ONLY_API=no

# Timezone (affects the daily auto-restart schedule below)
TIME_ZONE=Asia/Taipei

# 2FA handling
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TWOFA_EXIT_INTERVAL=300

# If another session is detected, defer to the secondary/manual login
EXISTING_SESSION_DETECTED_ACTION=secondary

# Auto-restart daily to keep the session alive (HH:MM AM/PM in TIME_ZONE).
# During this ~1-2 min window the API handshake fails — the watcher schedules
# (16:30 / 09:00) deliberately avoid it.
AUTO_RESTART_TIME=11:59 PM

# Weekly cold restart triggers 2FA — leave empty unless you want it.
TWS_COLD_RESTART=

# Accept incoming API connections automatically (leave empty for default).
TWS_ACCEPT_INCOMING=

# VNC password for GUI debugging (optional; empty disables VNC on :5900).
VNC_SERVER_PASSWORD=
